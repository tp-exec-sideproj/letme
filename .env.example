# AI Provider (any OpenAI-compatible endpoint)
AI_ENDPOINT=https://your-api-endpoint/v1
AI_KEY=your-api-key
AI_MODEL=your-model-name

# Azure Speech (for real-time transcription)
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus

# Google OAuth (for future Google sign-in / Calendar integration)
# Redirect URI: http://127.0.0.1 (Electron loopback)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
